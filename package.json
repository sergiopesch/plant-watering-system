{
  "name": "plant-watering-system",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.11"
  },
  "dependencies": {
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "three": "^0.184.0"
  },
  "scripts": {
    "check": "npm test && npm run build && npm run verify:ui",
    "ci": "npm run verify",
    "dev": "vite --host 0.0.0.0 --port 3001",
    "start": "vite --host 0.0.0.0 --port 3001",
    "build": "vite build",
    "docs:banner": "node scripts/capture-banner.mjs",
    "preview": "vite preview --host 0.0.0.0 --port 3001",
    "security:audit": "npm audit --omit=dev",
    "test": "vitest run",
    "verify": "npm run check && npm run security:audit",
    "verify:ui": "node scripts/verify-ui.mjs"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@vitejs/plugin-react": "^4.3.4",
    "jsdom": "^26.0.0",
    "pngjs": "^7.0.0",
    "vite": "^6.2.2",
    "vitest": "^3.0.8"
  },
  "overrides": {
    "follow-redirects": "1.16.0",
    "picomatch": "4.0.4",
    "yaml": "2.8.3"
  }
}
